+// Package contracts defines the canonical wire contracts for the V-Guard
+// Decision Engine. This file is a REFERENCE IMPLEMENTATION.
+//
+// ASSUMPTION NOTICE (read before merging):
+// The engineering handoff for Sprint B3-003 states that contracts/ already
+// exists as part of the frozen Production Architecture Baseline (PAB-1),
+// created in the initial bootstrap commit (c9b682c). This repository was
+// not accessible from the execution environment used to produce this patch
+// (authentication required), so the exact existing DecisionRequest shape
+// could not be read.
+//
+// If contracts/decision_request.go ALREADY EXISTS in the repository:
+//  1. Discard this file.
+//  2. Adjust the field references in internal/validator/request_validator.go
+//     to match the real contract. The validation RULES and ERROR SHAPE are
+//     contract-agnostic and do not need to change — only the field access
+//     expressions do.
+//
+// If it does NOT exist yet, this is a reasonable canonical shape based on
+// the fields already flowing through the V-Guard pipeline (POS intake ->
+// Fraud Processing Engine), and can be used as-is.
+package contracts
+
+import "time"
+
+// DecisionRequest is the canonical input to the Decision Engine.
+// It is intentionally free of any business-logic fields (risk scores,
+// thresholds, etc.) — those are produced BY the engine, never received.
+type DecisionRequest struct {
+	CorrelationID string    `json:"correlation_id"`
+	TransactionID string    `json:"transaction_id"`
+	StoreID       string    `json:"store_id"`
+	CashierID     string    `json:"cashier_id"`
+	Amount        float64   `json:"amount"`
+	Currency      string    `json:"currency"`
+	Items         []Item    `json:"items"`
+	Timestamp     time.Time `json:"timestamp"`
+}
+
+// Item represents a single line item within a transaction.
+type Item struct {
+	SKU       string  `json:"sku"`
+	Name      string  `json:"name"`
+	Quantity  int     `json:"quantity"`
+	UnitPrice float64 `json:"unit_price"`
+}
